DATABASE_URL="postgresql://user:password@localhost:5432/database_name"
PRISMA_CLIENT_ENGINE_TYPE="binary"
PRISMA_CLI_QUERY_ENGINE_TYPE="binary"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

NEXT_PUBLIC_APP_URL=http://localhost:3000

OPENAI_API_KEY=sk-proj-your_key_here
OPENAI_RESUME_MODEL=gpt-4o-mini
OPENAI_RESUME_TIMEOUT_MS=30000

# Optional: Sentry for error tracking
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_ORG=your_org
SENTRY_PROJECT=your_project

# Optional: Upstash Redis for rate limiting (use memory store in dev)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Redis for job queue
# Development default:
QUEUE_MODE=memory
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Production overrides (set in hosting env vars):
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# QUEUE_MODE=redis
# REDIS_URL=redis://user:password@host:6379
# ENFORCE_PROD_CHECKS=1
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# NOTE:
# - Keep localhost values only in `.env.local` for local development.
# - Vercel does NOT read your local `.env.local`; configure production env vars in Vercel dashboard.
